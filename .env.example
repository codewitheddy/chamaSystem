# ── Copy this to .env and fill in your real values ───────────────────────────

# Django core
SECRET_KEY=change-me-to-a-long-random-string-50-chars-minimum
DEBUG=False

# Your domain(s) — comma-separated, no spaces
# cPanel: use your actual domain e.g.  yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Must include the https:// prefix — required for CSRF to work in production
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Obfuscated admin path — change to something hard to guess
ADMIN_URL=secure-admin-path

# Brute-force protection
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1

# ── PostgreSQL (cPanel) ───────────────────────────────────────────────────────
# Create the DB + user in cPanel → PostgreSQL Databases first
DB_NAME=cpanelusername_chamadb
DB_USER=cpanelusername_chamauser
DB_PASSWORD=your-strong-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Base domain (for subdomain chama resolution) ─────────────────────────────
BASE_DOMAIN=yourdomain.com

# ── Email (cPanel SMTP) ───────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.yourdomain.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=Chama System <noreply@yourdomain.com>

# ── Billing ───────────────────────────────────────────────────────────────────
MPESA_PAYBILL=400200
MPESA_ACCOUNT_PREFIX=CHAMA
BILLING_CONTACT_EMAIL=billing@yourdomain.com
BILLING_CONTACT_PHONE=+254700000000

# ── Africa's Talking (SMS) — https://africastalking.com ──────────────────────
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=

# ── Twilio (WhatsApp) — https://twilio.com ───────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
